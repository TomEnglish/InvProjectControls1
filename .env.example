# Frontend (exposed to browser — VITE_ prefix required)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=

# Seed script / server-side tooling (never VITE_)
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=

# Edge Functions (set via `supabase secrets set` — not used in local dev)
RESEND_API_KEY=
NOTIFY_FROM_EMAIL=controls@invenio.app
SLACK_WEBHOOK_URL=
ATTACHMENTS_BUCKET=attachments
REPORTS_BUCKET=reports
ATTACHMENTS_MAX_MB=50
IMPORT_MAX_ROWS=50000
REPORT_SIGNED_URL_TTL_SECONDS=900
FORECAST_HORIZON_PERIODS=6
VARIANCE_CPI_THRESHOLD=0.95
VARIANCE_SPI_THRESHOLD=0.90
