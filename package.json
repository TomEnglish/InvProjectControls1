{
  "name": "invenio-projectcontrols",
  "version": "0.1.0",
  "private": true,
  "description": "Invenio ProjectControls — multi-tenant construction project-controls platform",
  "workspaces": [
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm -w frontend run dev",
    "build": "npm -w frontend run build",
    "lint": "npm -w frontend run lint",
    "typecheck": "npm -w frontend run typecheck && npm -w @invenio/schemas run typecheck",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff",
    "seed:minimal": "tsx scripts/seed/index.ts minimal",
    "seed:demo": "tsx scripts/seed/index.ts demo",
    "seed:stress": "tsx scripts/seed/index.ts stress"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
